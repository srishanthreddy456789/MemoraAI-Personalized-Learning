# =====================================================================
# .gitignore - Root level
# =====================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# Environment files - NEVER commit these
.env
.env.local
.env.production
.env.development
backend/.env

# SQLite database (runtime data, not source)
*.db
*.sqlite3
memory.db

# Node
node_modules/
.npm

# Build outputs
frontend/.next/
frontend/dist/
frontend/out/
frontend/.vercel/

# Testing
.coverage
htmlcov/
.pytest_cache/
coverage/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# MLflow / DVC
mlflow.db
artifacts/
