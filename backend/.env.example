# =====================================================================
# Backend Environment Variables - LOCAL DEVELOPMENT
# =====================================================================
# Copy this to .env and fill in your values for local development.
# For Render production, set these in the Render Dashboard:
#   Environment → Environment Variables

# JWT Secret Key (CHANGE THIS in production - use a long random string)
JWT_SECRET_KEY=local_dev_secret_change_in_production

# Allowed CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:8080

# Optional: Google Generative AI API Key (for GenAI features)
# GOOGLE_API_KEY=your_google_api_key_here

# Server port (Render will set this automatically)
# PORT=8000
